# ============================================
# abeTahta - Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın ve doldurun
# cp .env.example .env
# ============================================

# ---- Uygulama ----
NODE_ENV=development
APP_NAME=abeTahta
APP_URL=http://localhost:3000

# ---- Next.js Frontend ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4001

# ---- API Server ----
API_PORT=4000
API_HOST=0.0.0.0

# ---- WebSocket Server ----
WS_PORT=4001
WS_HOST=0.0.0.0

# ---- PostgreSQL ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=abetahta
DB_USER=postgres
DB_PASSWORD=your_strong_password_here
DATABASE_URL=postgresql://postgres:your_strong_password_here@localhost:5432/abetahta

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ---- JWT Authentication ----
JWT_SECRET=change_this_to_a_random_64_char_string
JWT_REFRESH_SECRET=change_this_to_another_random_64_char_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- Claude API ----
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096

# ---- Dosya Yükleme ----
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ---- CORS ----
CORS_ORIGIN=http://localhost:3000
