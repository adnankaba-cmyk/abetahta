{
  "name": "abetahta",
  "version": "1.0.0",
  "private": true,
  "description": "abeTahta - Gerçek Zamanlı Görsel İşbirliği Platformu",
  "author": "Adnan Kaba <adnan.kaba@abeerp.com>",
  "license": "UNLICENSED",
  "workspaces": [
    "packages/web",
    "packages/server"
  ],
  "scripts": {
    "dev": "concurrently -n web,api,ws -c blue,green,yellow \"npm run dev:web\" \"npm run dev:api\" \"npm run dev:ws\"",
    "dev:web": "npm run dev --workspace=packages/web",
    "dev:api": "npm run dev --workspace=packages/server",
    "dev:ws": "npm run dev:ws --workspace=packages/server",
    "build": "npm run build --workspace=packages/web && npm run build --workspace=packages/server",
    "db:migrate": "npm run migrate --workspace=packages/server",
    "db:seed": "npm run seed --workspace=packages/server",
    "lint": "eslint packages/*/src --ext .ts,.tsx",
    "clean": "rimraf packages/*/node_modules packages/*/.next packages/*/dist node_modules"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.1.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
